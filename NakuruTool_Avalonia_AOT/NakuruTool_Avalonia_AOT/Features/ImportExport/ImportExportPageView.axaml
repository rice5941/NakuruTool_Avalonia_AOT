<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:importExport="using:NakuruTool_Avalonia_AOT.Features.ImportExport"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="NakuruTool_Avalonia_AOT.Features.ImportExport.ImportExportPageView"
             x:DataType="importExport:ImportExportPageViewModel">

    <!-- 左右2列レイアウト: 左列(Export/進捗/Import) / 右列(BeatmapList) -->
    <Grid ColumnDefinitions="*,8,*">

        <!-- ─── Column 0: 左列 (Export上 / Import下) ─── -->
        <Grid Grid.Column="0" RowDefinitions="*,8,*">

            <!-- Row 0: Export（進捗はExportView内部に内包） -->
            <importExport:ExportView Grid.Row="0"
                                     DataContext="{Binding ExportViewModel}"/>

            <!-- Row 2: Import（進捗はImportView内部に内包） -->
            <importExport:ImportView Grid.Row="2"
                                     DataContext="{Binding ImportViewModel}"/>

        </Grid>

        <!-- ─── Column 2: 右列 (BeatmapListView全体) ─── -->
        <importExport:ImportExportBeatmapListView Grid.Column="2"
                                                   DataContext="{Binding BeatmapListViewModel}"/>

    </Grid>
</UserControl>
