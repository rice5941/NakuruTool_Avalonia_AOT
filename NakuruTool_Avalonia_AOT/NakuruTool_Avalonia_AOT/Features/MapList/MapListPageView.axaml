<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:MapList="using:NakuruTool_Avalonia_AOT.Features.MapList"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:translate="using:NakuruTool_Avalonia_AOT.Features.Translate"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:converters="using:NakuruTool_Avalonia_AOT.Features.Shared.Converters"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="600"
             x:Class="NakuruTool_Avalonia_AOT.Features.MapList.MapListPageView"
             x:DataType="MapList:MapListPageViewModel">

    <UserControl.Resources>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter" TrueOpacity="1.0" FalseOpacity="0.0"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource SemiGrey1}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SemiGrey3}"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*,Auto" ColumnDefinitions="320,*">
        <!-- 左側: フィルタパネル -->
        <MapList:MapFilterView Grid.Row="0" Grid.Column="0" 
                               DataContext="{Binding FilterViewModel}"/>
                
        <!-- コレクション生成パネル -->
        <Border Grid.Row="1" Grid.Column="0"
                BorderThickness="1" CornerRadius="4" BorderBrush="{DynamicResource SemiGrey3}" 
                Background="{DynamicResource SemiGrey0}" Margin="0,8,0,0">
            <Grid RowDefinitions="Auto,Auto">
                <!-- ヘッダー -->
                <Border Grid.Row="0" Background="{DynamicResource SemiGrey1}" 
                        BorderBrush="{DynamicResource SemiGrey3}" 
                        BorderThickness="0,0,0,1" 
                        Padding="12,8"
                        Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="Create" Width="20" Height="20" Foreground="{DynamicResource SemiBluePrimary}"/>
                        <TextBlock Text="{translate:Translate 'Collection.GenerateCollection'}" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Classes="card">
						<!-- コレクション名入力と追加ボタン -->
                    <Grid Grid.Row="1" RowDefinitions="auto,auto,auto" ColumnDefinitions="*,auto">
                        <TextBox Grid.Column="0" Grid.Row="0" VerticalAlignment="Center"
                                 Text="{Binding CollectionName, Mode=TwoWay}"
                                 Watermark="{translate:Translate 'Collection.EnterCollectionName'}"/>

                        <Button Grid.Column="1" Grid.Row="0"  Margin="12,0,0,0" Width="32" Height="32"
                                Command="{Binding AddToCollectionCommand}" Theme="{StaticResource SolidButton}" >
                            <mi:MaterialIcon Kind="ContentSave" Height="28" Width="28"/>
                        </Button>
                                
                        <!-- ステータスメッセージと進捗バー -->
                        <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" Margin="0,8,0,0">
                            <TextBlock Text="{Binding GenerationStatusMessage}" FontSize="12" Foreground="{DynamicResource SemiGrey7}"/>
                            <ProgressBar Value="{Binding GenerationProgressValue}" Maximum="100" 
                                         Height="4" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- 右側: 譜面リスト -->
        <MapList:MapListView Grid.Column="1" Grid.RowSpan="2" 
                             DataContext="{Binding ListViewModel}"
                             Margin="8,0,0,0"/>
    </Grid>
    
</UserControl>
