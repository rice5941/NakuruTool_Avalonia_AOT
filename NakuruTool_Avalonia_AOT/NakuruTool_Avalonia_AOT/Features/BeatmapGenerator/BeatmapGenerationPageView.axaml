<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:NakuruTool_Avalonia_AOT.Features.BeatmapGenerator"
             xmlns:MapList="using:NakuruTool_Avalonia_AOT.Features.MapList"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:translate="using:NakuruTool_Avalonia_AOT.Features.Translate"
             xmlns:converters="using:NakuruTool_Avalonia_AOT.Features.Shared.Converters"
             xmlns:sorting="using:NakuruTool_Avalonia_AOT.Features.MapList.Sorting"
             xmlns:sortingConv="using:NakuruTool_Avalonia_AOT.Features.MapList.Sorting.Converters"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="600"
             x:Class="NakuruTool_Avalonia_AOT.Features.BeatmapGenerator.BeatmapGenerationPageView"
             x:DataType="local:BeatmapGenerationPageViewModel">

    <UserControl.Resources>
        <sortingConv:SortFieldNameConverter x:Key="SortFieldNameConverter"/>

        <DataTemplate x:Key="SortRuleTemplate" DataType="sorting:SortRule">
            <Grid ColumnDefinitions="80,*,Auto,Auto" ColumnSpacing="8">
                <TextBlock Grid.Column="0"
                           Text="{Binding $parent[ContentControl].Tag}"
                           VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{x:Static sorting:MapListSortViewModel.SortFields}"
                          SelectedItem="{Binding Field}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="sorting:SortField">
                            <TextBlock Text="{Binding Converter={StaticResource SortFieldNameConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <RadioButton Grid.Column="2"
                             GroupName="{Binding $parent[ContentControl].Name}"
                             Content="{translate:Translate 'MapList.Sort.Ascending'}"
                             IsChecked="{Binding Direction,
                                                  Converter={x:Static converters:EnumToBoolConverter.Instance},
                                                  ConverterParameter={x:Static sorting:SortDirection.Ascending}}"/>
                <RadioButton Grid.Column="3"
                             GroupName="{Binding $parent[ContentControl].Name}"
                             Content="{translate:Translate 'MapList.Sort.Descending'}"
                             IsChecked="{Binding Direction,
                                                  Converter={x:Static converters:EnumToBoolConverter.Instance},
                                                  ConverterParameter={x:Static sorting:SortDirection.Descending}}"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid ColumnDefinitions="auto,8,550,8,*" Margin="0,0,0,8">

        <!-- Col 0: コレクション選択 -->
        <Border Grid.Column="0"
                BorderBrush="{DynamicResource SemiGrey3}"
                BorderThickness="1"
                CornerRadius="4"
                Background="{DynamicResource SemiGrey0}">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        Background="{DynamicResource SemiGrey1}"
                        BorderBrush="{DynamicResource SemiGrey3}"
                        BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <TextBlock Text="{translate:Translate 'BeatmapGen.SelectCollection'}"
                               FontSize="14"
                               FontWeight="Bold"/>
                </Border>

                <local:CollectionSelectorView Grid.Row="1"
                                              MinWidth="280"
                                              DataContext="{Binding CollectionSelector}"/>
            </Grid>
        </Border>

        
        <!-- Col 2: 生成設定 + 実行 -->
        <DockPanel Grid.Column="2"
               x:DataType="local:BeatmapGenerationPageViewModel">

            <!-- Bottom: 進捗 + ボタン -->
            <StackPanel DockPanel.Dock="Bottom"
                        Spacing="8"
                        x:DataType="local:BeatmapGenerationPageViewModel">
                <TextBlock Text="{Binding GenerationStatusMessage}" TextWrapping="Wrap"/>
                <ProgressBar Value="{Binding GenerationProgressValue}" Maximum="100"/>
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="{translate:Translate 'BeatmapGen.BatchGenerate'}"
                        Command="{Binding BatchGenerateCommand}"/>
                    <Button Content="{translate:Translate 'BeatmapGen.Cancel'}"
                        Command="{Binding CancelGenerationCommand}"/>
                </StackPanel>
            </StackPanel>

            <!-- Center: TabControl -->
            <TabControl SelectedIndex="{Binding SelectedGenerationTabIndex, Mode=TwoWay}"
                        x:DataType="local:BeatmapGenerationPageViewModel">
                <TabItem Header="{translate:Translate 'BeatmapGen.RateGeneration'}">
                    <local:RateGenerationView DataContext="{Binding RateGeneration}"/>
                </TabItem>
                <TabItem Header="{translate:Translate 'BeatmapGen.FLNGeneration'}" IsVisible="False">
                    <TextBlock Text="{translate:Translate 'BeatmapGen.ComingSoon'}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                FontSize="16" Opacity="0.5"/>
                </TabItem>
            </TabControl>

        </DockPanel>

        <!-- Col 4: ビートマップリスト (共通 MapListView) + Sort Overlay -->
        <Panel Grid.Column="4">
            <MapList:MapListView DataContext="{Binding}"
                                 ShowSortButton="True"
                                 SortCommand="{Binding ToggleSortOverlayCommand}"
                                 ShowAudioPlayer="False"
                                 ShowTotalCount="False"
                                 ShowFilteredCount="False"
                                 ShowResolvedCount="True"
                                 ShowHistoryColumn="False"
                                 ShowIsPlayedColumn="False"
                                 ScoreSystemGroupName="BeatmapGenScoreSystem"
                                 ModGroupName="BeatmapGenMod"
                                 DataGridRowHeight="80"/>

            <!-- Sort Overlay (右上に固定表示) -->
            <Border IsVisible="{Binding IsSortOverlayVisible}"
                    IsHitTestVisible="{Binding IsSortOverlayVisible}"
                    Background="#33000000"
                    ZIndex="10">
                <Border Theme="{DynamicResource CardBorder}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Width="420"
                        Margin="0,52,12,0"
                        Padding="20"
                        DataContext="{Binding SortViewModel}"
                        x:DataType="sorting:MapListSortViewModel">

                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="12">
                        <TextBlock Grid.Row="0"
                                   Text="{translate:Translate 'MapList.Sort.Title'}"
                                   FontSize="16" FontWeight="Bold"/>

                        <ContentControl Grid.Row="1"
                                        x:Name="BgPrimarySortRuleHost"
                                        Content="{Binding Primary}"
                                        Tag="{translate:Translate 'MapList.Sort.Priority1'}"
                                        ContentTemplate="{StaticResource SortRuleTemplate}"/>
                        <ContentControl Grid.Row="2"
                                        x:Name="BgSecondarySortRuleHost"
                                        Content="{Binding Secondary}"
                                        Tag="{translate:Translate 'MapList.Sort.Priority2'}"
                                        ContentTemplate="{StaticResource SortRuleTemplate}"/>
                        <ContentControl Grid.Row="3"
                                        x:Name="BgTertiarySortRuleHost"
                                        Content="{Binding Tertiary}"
                                        Tag="{translate:Translate 'MapList.Sort.Priority3'}"
                                        ContentTemplate="{StaticResource SortRuleTemplate}"/>

                        <StackPanel Grid.Row="4"
                                    Orientation="Horizontal" Spacing="8"
                                    HorizontalAlignment="Right">
                            <Button Content="{translate:Translate 'MapList.Sort.Reset'}"
                                    Command="{Binding ResetCommand}"/>
                            <Button Content="{translate:Translate 'MapList.Sort.Close'}"
                                    Command="{Binding $parent[local:BeatmapGenerationPageView].((local:BeatmapGenerationPageViewModel)DataContext).CloseSortOverlayCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>
        </Panel>

        <!-- 単体beatmap生成オーバーレイ (共通 UserControl) -->
        <local:SingleBeatmapGenerationOverlayView
            Grid.Column="0" Grid.ColumnSpan="5"
            IsVisible="{Binding IsSingleGenerationOverlayVisible}"
            ViewModel="{Binding SingleGenerationViewModel}"
            CloseCommand="{Binding CloseSingleGenerationCommand}"/>

    </Grid>
</UserControl>
