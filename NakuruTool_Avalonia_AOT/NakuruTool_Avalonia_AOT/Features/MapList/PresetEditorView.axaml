<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:MapList="using:NakuruTool_Avalonia_AOT.Features.MapList"
             xmlns:models="using:NakuruTool_Avalonia_AOT.Features.MapList.Models"
             xmlns:osu="using:NakuruTool_Avalonia_AOT.Features.OsuDatabase"
             xmlns:converters="using:NakuruTool_Avalonia_AOT.Features.Shared.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             xmlns:translate="using:NakuruTool_Avalonia_AOT.Features.Translate"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="NakuruTool_Avalonia_AOT.Features.MapList.PresetEditorView"
             x:DataType="MapList:PresetEditorViewModel">

    <UserControl.Styles>
        <!-- フィルタ条件カードのスタイル（MapFilterView.axamlからコピー） -->
        <Style Selector="Border.filter-card">
            <Setter Property="Background" Value="{DynamicResource SemiGrey1}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SemiGrey3}"/>
            <Setter Property="BorderThickness" Value="0,1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style Selector="TextBlock.filter-label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource SemiGrey6}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style Selector="ComboBox.filter-combobox">
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <Style Selector="TextBox.filter-input">
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
    </UserControl.Styles>

    <!-- 外枠: 2行構成 ヘッダー/コンテンツ -->
    <Grid RowDefinitions="Auto,*">

        <!-- Row 0: ヘッダー -->
        <Border Grid.Row="0"
                Background="{DynamicResource SemiGrey1}"
                BorderBrush="{DynamicResource SemiGrey3}"
                BorderThickness="1,1,1,0"
                CornerRadius="4,4,0,0"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <mi:MaterialIcon Kind="PlaylistEdit" Width="20" Height="20" Foreground="{DynamicResource SemiBluePrimary}"/>
                <TextBlock Text="{translate:Translate 'Preset.EditorTitle'}"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- Row 1: コンテンツ（左右分割） -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource SemiGrey3}"
                BorderThickness="1"
                CornerRadius="0,0,4,4">
            <Grid >
                <Grid.ColumnDefinitions>
				    <ColumnDefinition MinWidth="400" Width="400"/>
				    <ColumnDefinition Width="8"/>
				    <ColumnDefinition Width="*"/>	
                </Grid.ColumnDefinitions>

                <!-- Col 0: プリセット一覧パネル -->
                <Grid Grid.Column="0"
                      RowDefinitions="*,Auto">

                    <!-- Row 0: プリセット一覧 + 追加ボタン -->
                    <Grid Grid.Row="0"
                          RowDefinitions="*,Auto"
                          IsEnabled="{Binding IsNotBatchGenerating}">

                        <!-- Row 0: プリセット一覧 -->
                        <ListBox Grid.Row="0"
                                 ItemsSource="{Binding Presets}"
                                 SelectedItem="{Binding SelectedPreset}"
                                 Margin="8,8,4,4">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:FilterPreset">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Margin="4,2"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="330"/>
                                        <Button Grid.Column="1"
                                                Width="24" Height="24" Padding="0"
                                                Command="{Binding $parent[ListBox].((MapList:PresetEditorViewModel)DataContext).DeletePresetCommand}"
                                                CommandParameter="{Binding}"
                                                HorizontalAlignment="Right"
                                                ToolTip.Tip="{translate:Translate 'Preset.Delete'}">
                                            <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Row 1: 追加ボタン -->
                        <Button Grid.Row="1"
                                Command="{Binding AddNewPresetCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="8,2,4,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <mi:MaterialIcon Kind="Plus" Width="16" Height="16"/>
                                <TextBlock Text="{translate:Translate 'Preset.AddNew'}"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Row 1: 一括生成セクション（リスト外・ボーダー付き） -->
                    <Border Grid.Row="1"
                            BorderBrush="{DynamicResource SemiGrey3}"
                            BorderThickness="0,1,0,0"
                            Background="{DynamicResource SemiGrey1}"
                            Padding="8">
                        <StackPanel Spacing="6">
                            <Button Command="{Binding BatchGenerateCollectionsCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <mi:MaterialIcon Kind="PlaylistPlay" Width="16" Height="16"/>
                                    <TextBlock Text="{translate:Translate 'Preset.BatchGenerate'}"/>
                                </StackPanel>
                            </Button>

                            <!-- 一括生成進捗 -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding BatchGenerationStatusMessage}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SemiGrey6}"/>
                                <ProgressBar Value="{Binding BatchGenerationProgress}"
                                             Minimum="0"
                                             Maximum="100"
                                             Height="6"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Col 1: GridSplitter -->
                <GridSplitter Grid.Column="1"
                              Width="8"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"/>

                <!-- Col 2: 右側 編集パネル -->
                <Grid Grid.Column="2"
                      RowDefinitions="Auto,*,Auto"
                      IsEnabled="{Binding IsNotBatchGenerating}">

                    <!-- プリセット未選択時: 中央メッセージ -->
                    <TextBlock Grid.Row="0" Grid.RowSpan="3"
                               Text="{translate:Translate 'Preset.SelectToEdit'}"
                               IsVisible="{Binding !HasSelectedPreset}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SemiGrey5}"
                               FontSize="14"/>

                    <!-- プリセット選択時: Row 0 プリセット名テキストボックス -->
                    <StackPanel Grid.Row="0"
                                IsVisible="{Binding HasSelectedPreset}"
                                Spacing="4"
                                Margin="4,8,8,4">
                        <TextBlock Classes="filter-label"
                                   Text="{translate:Translate 'Preset.PresetName'}"/>
                        <TextBox Classes="filter-input"
                                 Text="{Binding EditingPresetName}"
                                 Watermark="{translate:Translate 'Preset.EnterPresetName'}"/>
                    </StackPanel>

                    <!-- プリセット選択時: Row 1 フィルタ条件リスト（ScrollViewer内） -->
                    <ScrollViewer Grid.Row="1"
                                  IsVisible="{Binding HasSelectedPreset}"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EditingConditions}"
                                      Margin="4,4,8,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:FilterCondition">
                                    <Border Classes="filter-card">
                                        <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                                            <!-- フィルタ対象選択 -->
                                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                                <TextBlock Classes="filter-label" Text="{translate:Translate 'MapFilter.Target'}"/>
                                                <Grid ColumnDefinitions="Auto,8,*,8,Auto">
                                                    <CheckBox Grid.Column="0"
                                                              Content="{translate:Translate 'MapFilter.Not'}"
                                                              IsChecked="{Binding IsNot}"
                                                              VerticalAlignment="Center"
                                                              FontSize="12"/>
                                                    <ComboBox Grid.Column="2"
                                                              Classes="filter-combobox"
                                                              ItemsSource="{x:Static MapList:MapFilterViewModel.FilterTargets}"
                                                              SelectedItem="{Binding Target}">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Converter={x:Static converters:FilterTargetToStringConverter.Instance}}"/>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>

                                                    <!-- 削除ボタン -->
                                                    <Button Grid.Column="4"
                                                            Width="32" Height="32"
                                                            Command="{Binding $parent[ItemsControl].((MapList:PresetEditorViewModel)DataContext).RemoveConditionCommand}"
                                                            CommandParameter="{Binding}">
                                                        <mi:MaterialIcon Kind="Close" Width="24" Height="24"/>
                                                    </Button>
                                                </Grid>
                                            </StackPanel>

                                            <!-- 比較条件選択（Collection以外のみ表示） -->
                                            <StackPanel Grid.Row="1" Margin="0,0,0,8"
                                                        IsVisible="{Binding !IsCollectionType}">
                                                <TextBlock Classes="filter-label" Text="{translate:Translate 'MapFilter.ComparisonType'}"/>
                                                <StackPanel Orientation="Horizontal" Spacing="24">
                                                    <RadioButton Content="="
                                                                 IsChecked="{Binding ComparisonType, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter={x:Static models:ComparisonType.Equals}}"
                                                                 IsEnabled="{Binding SupportsEquals}"
                                                                 GroupName="{Binding Id}"/>
                                                    <RadioButton Content="~"
                                                                 IsChecked="{Binding ComparisonType, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter={x:Static models:ComparisonType.Range}}"
                                                                 IsEnabled="{Binding SupportsRange}"
                                                                 GroupName="{Binding Id}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Mod選択（BestScore/BestAccuracy時のみ表示） -->
                                            <StackPanel Grid.Row="2" Margin="0,0,0,8"
                                                        IsVisible="{Binding IsScoreOrAccTarget}">
                                                <TextBlock Classes="filter-label" Text="{translate:Translate 'MapFilter.ScoreSystem'}"/>
                                                <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,0,0,6">
                                                    <RadioButton Content="{translate:Translate 'MapList.ScoreSystem.Default'}"
                                                                 IsChecked="{Binding ScoreSystemCategory, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter={x:Static osu:ScoreSystemCategory.Default}}"
                                                                 FontSize="13"/>
                                                    <RadioButton Content="{translate:Translate 'MapList.ScoreSystem.ScoreV2'}"
                                                                 IsChecked="{Binding ScoreSystemCategory, Converter={x:Static converters:EnumToBoolConverter.Instance}, ConverterParameter={x:Static osu:ScoreSystemCategory.ScoreV2}}"
                                                                 FontSize="13"/>
                                                </StackPanel>
                                                <TextBlock Classes="filter-label" Text="{translate:Translate 'MapFilter.ModCategory'}"/>
                                                <ComboBox Classes="filter-combobox"
                                                          ItemsSource="{x:Static models:FilterCondition.ModCategories}"
                                                          SelectedItem="{Binding ScoreModCategory}"
                                                          HorizontalAlignment="Stretch">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={x:Static converters:ModCategoryToStringConverter.Instance}}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>

                                            <!-- 値入力エリア -->
                                            <StackPanel Grid.Row="3">

                                                <!-- Collection選択（Collectionのみ表示） -->
                                                <StackPanel IsVisible="{Binding IsCollectionType}" Margin="0,0,0,8">
                                                    <TextBlock Classes="filter-label" Text="{translate:Translate 'MapFilter.Value'}"/>
                                                    <ComboBox Classes="filter-combobox"
                                                              ItemsSource="{Binding CollectionNames}"
                                                              SelectedItem="{Binding CollectionValue}"
                                                              HorizontalAlignment="Stretch"/>
                                                </StackPanel>

                                                <!-- 等価比較時の値入力（Collection以外のみ表示） -->
                                                <StackPanel IsVisible="{Binding IsNonCollectionEqual}" Margin="0,0,0,8">
                                                    <!-- 文字列入力 -->
                                                    <TextBox Classes="filter-input"
                                                             Text="{Binding Value}"
                                                             IsVisible="{Binding IsStringType}"
                                                             Watermark="{translate:Translate 'MapFilter.EnterText'}"/>

                                                    <!-- 数値入力 -->
                                                    <TextBox Classes="filter-input"
                                                             Text="{Binding Value}"
                                                             IsVisible="{Binding IsNumericType}"
                                                             Watermark="{translate:Translate 'MapFilter.EnterNumber'}"/>

                                                    <!-- 日付入力 -->
                                                    <CalendarDatePicker SelectedDate="{Binding DateValue, Mode=TwoWay}"
                                                                        IsVisible="{Binding IsDateType}"
                                                                        HorizontalAlignment="Stretch"/>

                                                    <!-- Bool選択 -->
                                                    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsBoolType}">
                                                        <RadioButton Content="{translate:Translate 'MapFilter.Yes'}"
                                                                     IsChecked="{Binding BoolValue}"/>
                                                        <RadioButton Content="{translate:Translate 'MapFilter.No'}"
                                                                     IsChecked="{Binding !BoolValue}"/>
                                                    </StackPanel>

                                                    <!-- Status選択 -->
                                                    <ComboBox Classes="filter-combobox"
                                                              ItemsSource="{x:Static MapList:MapFilterViewModel.StatusOptions}"
                                                              SelectedItem="{Binding StatusValue}"
                                                              IsVisible="{Binding IsEnumType}"/>

                                                        <!-- DrainTime入力（mm:ss形式） -->
                                                        <TextBox Classes="filter-input"
                                                                 Text="{Binding Value}"
                                                                 IsVisible="{Binding IsDurationType}"
                                                                 Watermark="mm:ss"/>
                                                </StackPanel>

                                                <!-- 範囲比較時の入力（横並び） -->
                                                <Grid IsVisible="{Binding IsRangeComparison}"
                                                      ColumnDefinitions="*,8,*"
                                                      Margin="0,0,0,8">

                                                    <!-- 最小値 -->
                                                    <StackPanel Grid.Column="0" Spacing="8">
                                                        <StackPanel Orientation="Vertical" Spacing="2">
                                                            <TextBlock Classes="filter-label" Text="{translate:Translate 'MapFilter.ValueMin'}"/>
                                                            <CheckBox Content="{translate:Translate 'MapFilter.IncludeBoundary'}"
                                                                      IsChecked="{Binding MinBoundaryType, Converter={x:Static converters:BoundaryTypeInclusiveToBoolConverter.Instance}, Mode=TwoWay}"
                                                                      FontSize="11"/>
                                                        </StackPanel>

                                                        <!-- 数値最小値 -->
                                                        <TextBox Classes="filter-input"
                                                                 Text="{Binding Value}"
                                                                 IsVisible="{Binding IsNumericType}"
                                                                 Watermark="{translate:Translate 'MapFilter.EnterMinNumber'}"/>

                                                        <!-- 日付最小値 -->
                                                        <CalendarDatePicker SelectedDate="{Binding DateValue, Mode=TwoWay}"
                                                                            IsVisible="{Binding IsDateType}"
                                                                            HorizontalAlignment="Stretch"/>

                                                            <!-- DrainTime最小値 -->
                                                            <TextBox Classes="filter-input"
                                                                     Text="{Binding Value}"
                                                                     IsVisible="{Binding IsDurationType}"
                                                                     Watermark="mm:ss"/>
                                                    </StackPanel>

                                                    <!-- 最大値 -->
                                                    <StackPanel Grid.Column="2" Spacing="8">
                                                        <StackPanel Orientation="Vertical" Spacing="2">
                                                            <TextBlock Classes="filter-label" Text="{translate:Translate 'MapFilter.ValueMax'}"/>
                                                            <CheckBox Content="{translate:Translate 'MapFilter.IncludeBoundary'}"
                                                                      IsChecked="{Binding MaxBoundaryType, Converter={x:Static converters:BoundaryTypeInclusiveToBoolConverter.Instance}, Mode=TwoWay}"
                                                                      FontSize="11"/>
                                                        </StackPanel>

                                                        <!-- 数値最大値 -->
                                                        <TextBox Classes="filter-input"
                                                                 Text="{Binding ValueMax}"
                                                                 IsVisible="{Binding IsNumericType}"
                                                                 Watermark="{translate:Translate 'MapFilter.EnterMaxNumber'}"/>

                                                        <!-- 日付最大値 -->
                                                        <CalendarDatePicker SelectedDate="{Binding DateValueMax, Mode=TwoWay}"
                                                                            IsVisible="{Binding IsDateType}"
                                                                            HorizontalAlignment="Stretch"/>

                                                            <!-- DrainTime最大値 -->
                                                            <TextBox Classes="filter-input"
                                                                     Text="{Binding ValueMax}"
                                                                     IsVisible="{Binding IsDurationType}"
                                                                     Watermark="mm:ss"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- プリセット選択時: Row 2 操作ボタン（スクロール外・常時表示） -->
                    <Border Grid.Row="2"
                            IsVisible="{Binding HasSelectedPreset}"
                            BorderBrush="{DynamicResource SemiGrey3}"
                            BorderThickness="0,1,0,0"
                            Background="{DynamicResource SemiGrey1}"
                            Padding="8">
                        <StackPanel Spacing="6">
                            <!-- ステータスメッセージ -->
                            <TextBlock Text="{Binding EditorStatusMessage}"
                                       FontSize="12"
                                       Foreground="{DynamicResource SemiGrey6}"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                            <Button Command="{Binding AddConditionCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <mi:MaterialIcon Kind="Plus" Width="16" Height="16"/>
                                    <TextBlock Text="{translate:Translate 'MapFilter.AddCondition'}"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ClearConditionsCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <mi:MaterialIcon Kind="DeleteSweep" Width="16" Height="16"/>
                                    <TextBlock Text="{translate:Translate 'MapFilter.ClearConditions'}"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SavePresetCommand}"
                                    Theme="{StaticResource SolidButton}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <mi:MaterialIcon Kind="ContentSave" Width="16" Height="16"/>
                                    <TextBlock Text="{translate:Translate 'Preset.Save'}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

    </Grid>

</UserControl>