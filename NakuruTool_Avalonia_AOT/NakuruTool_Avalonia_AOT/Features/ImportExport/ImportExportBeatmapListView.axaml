<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:importExport="using:NakuruTool_Avalonia_AOT.Features.ImportExport"
             xmlns:models="using:NakuruTool_Avalonia_AOT.Features.ImportExport.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="400"
             xmlns:translate="using:NakuruTool_Avalonia_AOT.Features.Translate"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:converters="using:NakuruTool_Avalonia_AOT.Features.Shared.Converters"
             x:Class="NakuruTool_Avalonia_AOT.Features.ImportExport.ImportExportBeatmapListView"
             x:DataType="importExport:ImportExportBeatmapListViewModel">

    <UserControl.Resources>
        <converters:DownloadStateVisibilityConverter x:Key="DownloadStateVisibilityConverter"/>
        <converters:DownloadStateCanDownloadConverter x:Key="DownloadStateCanDownloadConverter"/>
        <converters:UnicodeDisplayConverter x:Key="UnicodeDisplayConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- DataGrid全体のスタイル -->
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="{DynamicResource SemiGrey1}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SemiGrey3}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="48"/>
        </Style>

        <!-- ヘッダーセルのスタイル -->
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SemiGrey2}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SemiGrey3}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <!-- データセルのスタイル -->
        <Style Selector="DataGridCell">
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SemiGrey2}"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>

        <!-- 行の交互背景色 -->
        <Style Selector="DataGridRow:nth-child(even)">
            <Setter Property="Background" Value="{DynamicResource SemiGrey0}"/>
        </Style>

        <Style Selector="DataGridRow:nth-child(odd)">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- 行ホバー時のスタイル -->
        <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource SemiBlue0}"/>
        </Style>

        <!-- プライマリ値のスタイル -->
        <Style Selector="TextBlock.primary-value">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SemiGrey9}"/>
        </Style>

        <!-- セカンダリ値のスタイル -->
        <Style Selector="TextBlock.secondary-value">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource SemiGrey7}"/>
        </Style>

        <!-- 数値中央寄せのスタイル -->
        <Style Selector="TextBlock.numeric-value">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <!-- ダウンロードボタンのスタイル -->
        <Style Selector="Button.download-btn">
            <Setter Property="Padding" Value="4"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Row 0: ヘッダー（件数表示 + 一括DLボタン） -->
        <Border Grid.Row="0" Background="{DynamicResource SemiGrey1}"
                BorderBrush="{DynamicResource SemiGrey3}"
                BorderThickness="1,1,1,0"
                CornerRadius="4,4,0,0"
                Padding="12,8">
            <Grid ColumnDefinitions="*,Auto">
                <!-- 左: 件数表示 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <mi:MaterialIcon Kind="MusicNote" Width="20" Height="20"
                                     Foreground="{DynamicResource SemiBluePrimary}"/>
                    <TextBlock Text="{translate:Translate 'ImportExport.PreviewCount'}"
                               VerticalAlignment="Center" FontSize="14"/>
                    <Border CornerRadius="12" Padding="12,4">
                        <TextBlock Text="{Binding TotalPreviewCount}"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="13"/>
                    </Border>
                </StackPanel>

                <!-- 右: ダウンロードボタン（Importプレビュー時のみ表示） -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            IsVisible="{Binding IsImportPreview}">
                    <Button Command="{Binding DownloadAllMissingCommand}"
                            ToolTip.Tip="{translate:Translate 'ImportExport.DownloadAllMissing'}"
                            Theme="{StaticResource SolidButton}" Padding="8,4">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="DownloadMultiple" Width="16" Height="16"/>
                            <TextBlock Text="{translate:Translate 'ImportExport.DownloadAll'}"
                                       FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding CancelDownloadsCommand}"
                            ToolTip.Tip="{translate:Translate 'ImportExport.CancelDownloads'}"
                            Theme="{StaticResource SolidButton}" Padding="8,4">
                        <mi:MaterialIcon Kind="Cancel" Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: DataGrid -->
        <DataGrid Grid.Row="1"
                  x:Name="BeatmapGrid"
                  ItemsSource="{Binding ShowBeatmaps}"
                  IsReadOnly="True"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Single">
            <DataGrid.Columns>

                <!-- キー数 -->
                <DataGridTemplateColumn Width="80">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="{translate:Translate 'ImportExport.KeyCount'}"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:ImportExportBeatmapItem">
                            <TextBlock Text="{Binding KeyCount, StringFormat={}{0}K}"
                                       Classes="numeric-value"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontSize="13"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 曲情報: タイトル・バージョン（1行目）/ アーティスト・作成者（2行目） -->
                <DataGridTemplateColumn Width="*" MinWidth="200">
                    <DataGridTemplateColumn.Header>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="Music" Width="16" Height="16"/>
                            <TextBlock Text="{translate:Translate 'ImportExport.Title'}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:ImportExportBeatmapItem">
                            <StackPanel Spacing="1" Margin="4,0" VerticalAlignment="Center">
                                <!-- 1行目: タイトル + バージョン -->
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding ., Converter={StaticResource UnicodeDisplayConverter}, ConverterParameter=Title}"
                                               Classes="song-primary"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Version}"
                                               Classes="song-primary"
                                               Opacity="0.7"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <!-- 2行目: アーティスト + 作成者 -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding ., Converter={StaticResource UnicodeDisplayConverter}, ConverterParameter=Artist}"
                                               Classes="song-secondary"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Creator}"
                                               Classes="song-secondary"
                                               Opacity="0.85"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Exists/Download列（最終列: Importプレビュー時のみ表示） -->
                <DataGridTemplateColumn Width="100">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="{translate:Translate 'ImportExport.Exists'}"
                                   HorizontalAlignment="Center"/>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:ImportExportBeatmapItem">
                            <Panel HorizontalAlignment="Center" VerticalAlignment="Center">

                                <!-- 状態: Exists（DB存在）→ 緑チェック -->
                                <mi:MaterialIcon Width="20" Height="20"
                                    Kind="CheckCircleOutline"
                                    Foreground="{DynamicResource SemiColorSuccess}"
                                    IsVisible="{Binding DownloadState, Converter={StaticResource DownloadStateVisibilityConverter}, ConverterParameter=Exists}"/>

                                <!-- 状態: NotExists + CanDownload → DLボタン -->
                                <Button Classes="download-btn"
                                        Command="{Binding $parent[DataGrid].((importExport:ImportExportBeatmapListViewModel)DataContext).DownloadBeatmapCommand}"
                                        CommandParameter="{Binding}"
                                        ToolTip.Tip="{translate:Translate 'ImportExport.Download'}">
                                    <Button.IsVisible>
                                        <MultiBinding Converter="{StaticResource DownloadStateCanDownloadConverter}"
                                                      ConverterParameter="NotExistsCanDownload">
                                            <Binding Path="DownloadState"/>
                                            <Binding Path="CanDownload"/>
                                        </MultiBinding>
                                    </Button.IsVisible>
                                    <mi:MaterialIcon Width="20" Height="20" Kind="Download"
                                                     Foreground="{DynamicResource SemiGrey7}"/>
                                </Button>

                                <!-- 状態: NotExists + !CanDownload → グレーアウトアイコン -->
                                <mi:MaterialIcon Width="20" Height="20"
                                    Kind="DownloadOff"
                                    Foreground="{DynamicResource SemiGrey7}"
                                    Opacity="0.5"
                                    ToolTip.Tip="{translate:Translate 'ImportExport.DownloadUnavailable'}">
                                    <mi:MaterialIcon.IsVisible>
                                        <MultiBinding Converter="{StaticResource DownloadStateCanDownloadConverter}"
                                                      ConverterParameter="NotExistsNoDownload">
                                            <Binding Path="DownloadState"/>
                                            <Binding Path="CanDownload"/>
                                        </MultiBinding>
                                    </mi:MaterialIcon.IsVisible>
                                </mi:MaterialIcon>

                                <!-- 状態: Queued → 時計アイコン -->
                                <mi:MaterialIcon Width="20" Height="20"
                                    Kind="Clock"
                                    Foreground="{DynamicResource SemiGrey7}"
                                    IsVisible="{Binding DownloadState, Converter={StaticResource DownloadStateVisibilityConverter}, ConverterParameter=Queued}"/>

                                <!-- 状態: Downloading → 回転ローディング -->
                                <mi:MaterialIcon Width="20" Height="20"
                                    Kind="Loading"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource SemiGrey7}"
                                    IsVisible="{Binding DownloadState, Converter={StaticResource DownloadStateVisibilityConverter}, ConverterParameter=Downloading}">
                                    <mi:MaterialIcon.RenderTransform>
                                        <RotateTransform/>
                                    </mi:MaterialIcon.RenderTransform>
                                    <mi:MaterialIcon.Styles>
                                        <Style Selector="mi|MaterialIcon">
                                            <Style.Animations>
                                                <Animation Duration="0:0:1" IterationCount="INFINITE">
                                                    <KeyFrame Cue="0%">
                                                        <Setter Property="RotateTransform.Angle" Value="0"/>
                                                    </KeyFrame>
                                                    <KeyFrame Cue="100%">
                                                        <Setter Property="RotateTransform.Angle" Value="360"/>
                                                    </KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </mi:MaterialIcon.Styles>
                                </mi:MaterialIcon>

                                <!-- 状態: Downloaded → 完了チェック -->
                                <mi:MaterialIcon Width="20" Height="20"
                                    Kind="CheckCircle"
                                    Foreground="{DynamicResource SemiColorSuccess}"
                                    IsVisible="{Binding DownloadState, Converter={StaticResource DownloadStateVisibilityConverter}, ConverterParameter=Downloaded}"/>

                                <!-- 状態: Error → エラーアイコン + リトライボタン -->
                                <StackPanel Orientation="Horizontal" Spacing="4"
                                            IsVisible="{Binding DownloadState, Converter={StaticResource DownloadStateVisibilityConverter}, ConverterParameter=Error}">
                                    <mi:MaterialIcon Width="18" Height="18"
                                        Kind="AlertCircle"
                                        Foreground="{DynamicResource SemiColorDanger}"/>
                                    <Button Classes="download-btn"
                                            Command="{Binding $parent[DataGrid].((importExport:ImportExportBeatmapListViewModel)DataContext).DownloadBeatmapCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="{Binding ErrorMessage}">
                                        <mi:MaterialIcon Width="14" Height="14" Kind="Refresh"/>
                                    </Button>
                                </StackPanel>

                            </Panel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 2: ページネーション -->
        <Border Grid.Row="2"
                Background="{DynamicResource SemiGrey1}"
                BorderBrush="{DynamicResource SemiGrey3}"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,4,4"
                Padding="12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
                <Button Command="{Binding PreviousPageCommand}"
                        Theme="{StaticResource SolidButton}" Width="40" Height="40">
                    <mi:MaterialIcon Kind="ChevronLeft" Height="32" Width="32"/>
                </Button>
                <Border Background="{DynamicResource SemiGrey2}"
                        CornerRadius="6"
                        Padding="16,8">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentPage}"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Foreground="{DynamicResource SemiBluePrimary}"/>
                        <TextBlock Text="/" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="{Binding FilteredPages}" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Button Command="{Binding NextPageCommand}"
                        Theme="{StaticResource SolidButton}" Width="40" Height="40">
                    <mi:MaterialIcon Kind="ChevronRight" Height="32" Width="32"/>
                </Button>
                <ComboBox Width="80"
                          ItemsSource="{Binding PageSizes}"
                          SelectedItem="{Binding PageSize, Mode=TwoWay}"
                          TextElement.FontSize="16"
                          TextElement.FontWeight="Bold"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>

</UserControl>
