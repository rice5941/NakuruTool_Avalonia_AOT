<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:MapList="using:NakuruTool_Avalonia_AOT.Features.MapList"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="600"
             x:Class="NakuruTool_Avalonia_AOT.Features.MapList.MapListPageView"
             x:DataType="MapList:MapListPageViewModel">

    <Grid ColumnDefinitions="320,*">
        <!-- 左側: フィルタパネル -->
        <MapList:MapFilterView DataContext="{Binding FilterViewModel}"/>
        
        <!-- 右側: 譜面リスト -->
        <MapList:MapListView Grid.Column="1" 
                             DataContext="{Binding ListViewModel}"
                             Margin="8,0,0,0"/>
    </Grid>
    
</UserControl>
