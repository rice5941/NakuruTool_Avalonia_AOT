<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:MapList="using:NakuruTool_Avalonia_AOT.Features.MapList"
             xmlns:BeatmapGen="using:NakuruTool_Avalonia_AOT.Features.BeatmapGenerator"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:translate="using:NakuruTool_Avalonia_AOT.Features.Translate"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:converters="using:NakuruTool_Avalonia_AOT.Features.Shared.Converters"
             xmlns:sorting="using:NakuruTool_Avalonia_AOT.Features.MapList.Sorting"
             xmlns:sortingConv="using:NakuruTool_Avalonia_AOT.Features.MapList.Sorting.Converters"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="600"
             x:Class="NakuruTool_Avalonia_AOT.Features.MapList.MapListPageView"
             x:DataType="MapList:MapListPageViewModel">

    <UserControl.Resources>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter" TrueOpacity="1.0" FalseOpacity="0.0"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:BoolToIconKindConverter x:Key="PlayPauseIconConverter" TrueIcon="Pause" FalseIcon="Play"/>

        <sortingConv:SortFieldNameConverter x:Key="SortFieldNameConverter"/>

        <DataTemplate x:Key="SortRuleTemplate" DataType="sorting:SortRule">
            <Grid ColumnDefinitions="80,*,Auto,Auto" ColumnSpacing="8">
                <TextBlock Grid.Column="0"
                           Text="{Binding $parent[ContentControl].Tag}"
                           VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{x:Static sorting:MapListSortViewModel.SortFields}"
                          SelectedItem="{Binding Field}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="sorting:SortField">
                            <TextBlock Text="{Binding Converter={StaticResource SortFieldNameConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <RadioButton Grid.Column="2"
                             GroupName="{Binding $parent[ContentControl].Name}"
                             Content="{translate:Translate 'MapList.Sort.Ascending'}"
                             IsChecked="{Binding Direction,
                                                  Converter={x:Static converters:EnumToBoolConverter.Instance},
                                                  ConverterParameter={x:Static sorting:SortDirection.Ascending}}"/>
                <RadioButton Grid.Column="3"
                             GroupName="{Binding $parent[ContentControl].Name}"
                             Content="{translate:Translate 'MapList.Sort.Descending'}"
                             IsChecked="{Binding Direction,
                                                  Converter={x:Static converters:EnumToBoolConverter.Instance},
                                                  ConverterParameter={x:Static sorting:SortDirection.Descending}}"/>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource SemiGrey1}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SemiGrey3}"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
    </UserControl.Styles>

    <Panel>
        <Grid RowDefinitions="*,Auto" ColumnDefinitions="320,*">
            <!-- 左側: フィルタパネル -->
            <MapList:MapFilterView Grid.Row="0" Grid.Column="0"
                                   DataContext="{Binding FilterViewModel}"/>
                
            <!-- コレクション生成パネル -->
            <Border Grid.Row="1" Grid.Column="0"
                    BorderThickness="1" CornerRadius="4" BorderBrush="{DynamicResource SemiGrey3}" 
                    Background="{DynamicResource SemiGrey0}" Margin="0,8,0,0">
                <Grid RowDefinitions="Auto,Auto">
                    <!-- ヘッダー -->
                    <Border Grid.Row="0" Background="{DynamicResource SemiGrey1}" 
                            BorderBrush="{DynamicResource SemiGrey3}" 
                            BorderThickness="0,0,0,1" 
                            Padding="12,8"
                            Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Create" Width="20" Height="20" Foreground="{DynamicResource SemiBluePrimary}"/>
                            <TextBlock Text="{translate:Translate 'Collection.GenerateCollection'}" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Classes="card">
						    <!-- コレクション名入力と追加ボタン -->
                        <Grid Grid.Row="1" RowDefinitions="auto,auto,auto" ColumnDefinitions="*,auto">
                            <TextBox Grid.Column="0" Grid.Row="0" VerticalAlignment="Center"
                                     Text="{Binding CollectionName, Mode=TwoWay}"
                                     Watermark="{translate:Translate 'Collection.EnterCollectionName'}"/>

                            <Button Grid.Column="1" Grid.Row="0"  Margin="12,0,0,0" Width="32" Height="32"
                                    Command="{Binding AddToCollectionCommand}" Theme="{StaticResource SolidButton}" >
                                <mi:MaterialIcon Kind="ContentSave" Height="28" Width="28"/>
                            </Button>
                                
                            <!-- ステータスメッセージと進捗バー -->
                            <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2" Margin="0,8,0,0">
                                <TextBlock Text="{Binding GenerationStatusMessage}" FontSize="12" Foreground="{DynamicResource SemiGrey7}"/>
                                <ProgressBar Value="{Binding GenerationProgressValue}" Maximum="100" 
                                             Height="4" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- 右側: 譜面リスト（通常表示時） -->
            <Panel Grid.Column="1" Grid.RowSpan="2"
                   Margin="8,0,0,0"
                   IsVisible="{Binding !IsPresetEditorVisible}">
                <MapList:MapListView DataContext="{Binding ListViewModel}"
                                     ShowSortButton="True"
                                     SortCommand="{Binding $parent[MapList:MapListPageView].((MapList:MapListPageViewModel)DataContext).ToggleSortOverlayCommand}"/>

                <!-- Sort Overlay (右上に固定表示) -->
                <Border IsVisible="{Binding IsSortOverlayVisible}"
                        IsHitTestVisible="{Binding IsSortOverlayVisible}"
                        Background="#33000000"
                        ZIndex="10">
                    <Border Theme="{DynamicResource CardBorder}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Width="420"
                            Margin="0,52,12,0"
                            Padding="20"
                            DataContext="{Binding ListViewModel.SortViewModel}"
                            x:DataType="sorting:MapListSortViewModel">

                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="12">
                            <TextBlock Grid.Row="0"
                                       Text="{translate:Translate 'MapList.Sort.Title'}"
                                       FontSize="16" FontWeight="Bold"/>

                            <ContentControl Grid.Row="1"
                                            x:Name="PrimarySortRuleHost"
                                            Content="{Binding Primary}"
                                            Tag="{translate:Translate 'MapList.Sort.Priority1'}"
                                            ContentTemplate="{StaticResource SortRuleTemplate}"/>
                            <ContentControl Grid.Row="2"
                                            x:Name="SecondarySortRuleHost"
                                            Content="{Binding Secondary}"
                                            Tag="{translate:Translate 'MapList.Sort.Priority2'}"
                                            ContentTemplate="{StaticResource SortRuleTemplate}"/>
                            <ContentControl Grid.Row="3"
                                            x:Name="TertiarySortRuleHost"
                                            Content="{Binding Tertiary}"
                                            Tag="{translate:Translate 'MapList.Sort.Priority3'}"
                                            ContentTemplate="{StaticResource SortRuleTemplate}"/>

                            <StackPanel Grid.Row="4"
                                        Orientation="Horizontal" Spacing="8"
                                        HorizontalAlignment="Right">
                                <Button Content="{translate:Translate 'MapList.Sort.Reset'}"
                                        Command="{Binding ResetCommand}"/>
                                <Button Content="{translate:Translate 'MapList.Sort.Close'}"
                                        Command="{Binding $parent[MapList:MapListPageView].((MapList:MapListPageViewModel)DataContext).CloseSortOverlayCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Border>
            </Panel>

            <!-- 右側: プリセット編集（編集モード時） -->
            <Panel Grid.Column="1" Grid.RowSpan="2"
                   Margin="8,0,0,0"
                   IsVisible="{Binding IsPresetEditorVisible}">
                <MapList:PresetEditorView DataContext="{Binding PresetEditorViewModel}"/>
            </Panel>
        </Grid>

        <!-- 大量件数確認オーバーレイ -->
        <Border IsVisible="{Binding IsLargeCollectionConfirmVisible}"
                Background="#80000000"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Theme="{DynamicResource CardBorder}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="400" MaxWidth="500" Padding="24">
                <StackPanel Spacing="16">
                    <!-- 警告アイコン + タイトル -->
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="AlertCircleOutline" Width="24" Height="24"
                                         Foreground="#E6A700"/>
                        <TextBlock Text="{translate:Translate 'Collection.ConfirmLargeCollectionTitle'}"
                                   FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 確認メッセージ（件数を含む動的テキスト） -->
                    <TextBlock Text="{Binding LargeCollectionConfirmMessage}"
                               TextWrapping="Wrap" TextAlignment="Center"/>

                    <!-- OK / キャンセル ボタン -->
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                        <Button Command="{Binding ConfirmLargeCollectionCommand}"
                                Content="{translate:Translate 'Collection.ConfirmOk'}"
                                Theme="{StaticResource SolidButton}"
                                MinWidth="100"/>
                        <Button Command="{Binding CancelLargeCollectionCommand}"
                                Content="{translate:Translate 'Collection.ConfirmCancel'}"
                                MinWidth="100"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- 単体beatmap生成オーバーレイ (共通 UserControl) -->
        <BeatmapGen:SingleBeatmapGenerationOverlayView
            IsVisible="{Binding IsSingleGenerationOverlayVisible}"
            ViewModel="{Binding SingleGenerationViewModel}"
            CloseCommand="{Binding CloseSingleGenerationCommand}"/>
    </Panel>

</UserControl>
